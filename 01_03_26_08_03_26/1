
import random

znach = random.randrange(5,95,5)



while znach < 100:
    kopeka = input(f'Введите количество копеек необходимых для того, чтобы в сумме получился 1 рубль.\n'
                   f'Ты можешь добавить 5, 10 или 50 копеек. Значение сейчас: {znach}\n'
                   f'')
    if kopeka == '5':
        znach += 5
    elif kopeka == "10":
        znach += 10
    elif kopeka == '50':
        znach += 50
    else:
        print('Ты выбрал неправильное количество копеек или написал нечисленное значение')


if znach > 100:
    print('Ты проиграл')
else: print('Молодец, ты выиграл')
